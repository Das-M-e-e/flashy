{
  "name": "flashy-desktop",
  "version": "1.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Das-M-e-e/flashy.git"
  },
  "private": true,
  "description": "Flashy als Desktop-App (Electron)",
  "author": "Flashy",
  "main": "dist/main.js",
  "scripts": {
    "make-icon": "node scripts/make-icon.mjs",
    "bundle:server": "esbuild ../server/src/index.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/server.cjs --external:node:sqlite",
    "build:main": "tsc -p tsconfig.json",
    "build": "npm run make-icon && npm run bundle:server && npm run build:main",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0"
  },
  "build": {
    "appId": "com.flashy.app",
    "productName": "Flashy",
    "electronVersion": "43.1.0",
    "publish": [
      { "provider": "github" }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "../client/dist", "to": "client/dist" },
      { "from": "../skills", "to": "skills" },
      { "from": "build/icon.png", "to": "icon.png" }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "shortcutName": "Flashy"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": "universal" }],
      "category": "public.app-category.education"
    },
    "linux": { "target": ["AppImage"], "category": "Education" }
  }
}
